<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.ScoreBoardPage"
             Title="Игра">

    <Grid RowDefinitions="2*, 5*, 3*" 
          Padding="10"
          RowSpacing="10">

        <!-- ВЕРХНЯЯ ЧАСТЬ: ПАРТИИ И НАЗВАНИЯ -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto, *" RowDefinitions="auto">

            <Label Text="Хозяева" 
                   Grid.Column="0" 
                   FontSize="24" 
                   TextColor="Black" 
                   VerticalOptions="Center" 
                   HorizontalOptions="Center">
            </Label>

            <Label Text="1" 
                   Grid.Column="1" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="Black" 
                   VerticalTextAlignment="Center">
            </Label>

            <Button Grid.Column="2" 
                    Text="Swap" 
                    FontSize="Title" 
                    TextColor="Black" 
                    Margin="20,0,20,0">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Gray"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkGray"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Label Text="1" 
                   Grid.Column="3" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="Black" 
                   VerticalTextAlignment="Center">
            </Label>

            <Label Text="Гости" 
                   Grid.Column="4" 
                   FontSize="24" 
                   TextColor="Black" 
                   VerticalOptions="Center" 
                   HorizontalOptions="Center">
            </Label>

        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, *">

            <Button Grid.Column="0" 
                    Text="21" 
                    FontSize="52" 
                    Margin="0,0,30,0">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Button Grid.Column="2" 
                    Text="23" 
                    FontSize="52" 
                    Margin="30,0,0,0">
                
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="10*, 7*, 7*, 7*, 7*, 10*" RowDefinitions="*">

            <Button Grid.Row="1" 
                    Grid.Column="0" 
                    VerticalOptions="Center" 
                    Margin="0,0,10,0" 
                    Text="Текущая расстановка">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Button Grid.Row="1" 
                    Grid.Column="1" 
                    VerticalOptions="Center" 
                    Margin="0,0,10,0" 
                    Text="Таймауты">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Button Grid.Row="1" 
                    Grid.Column="2" 
                    VerticalOptions="Center" 
                    Margin="0,0,30,0" 
                    Text="Замены">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Button Grid.Row="1" 
                    Grid.Column="3" 
                    VerticalOptions="Center" 
                    Margin="30,0,0,0" 
                    Text="Замены">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Button Grid.Row="1" 
                    Grid.Column="4" 
                    VerticalOptions="Center" 
                    Margin="10,0,0,0" 
                    Text="Таймауты">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <Button Grid.Row="1" 
                    Grid.Column="5" 
                    VerticalOptions="Center" 
                    Margin="10,0,0,0" 
                    Text="Текущая расстановка">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="BlueViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="DarkViolet"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

        </Grid>
        
    </Grid>
    
</ContentPage>