<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.RosterPage"
             Title="Заявки команд">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame BorderColor="#007ACC" CornerRadius="10" Padding="10">
                <VerticalStackLayout>
                    <Label Text="Команда Хозяев" FontSize="18" FontAttributes="Bold" 
                           TextColor="#007ACC"/>

                    <!-- Список игроков -->
                    <CollectionView x:Name="TeamHomeList" HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="40,*,Auto,Auto,40" Padding="5">
                                    
                                    <!-- Номер -->
                                    <Entry Grid.Column="0" Text="{Binding Number}" 
                                           Keyboard="Numeric" Placeholder="№"
                                           HorizontalTextAlignment="Center"/>
                                    
                                    <!-- ФИО -->
                                    <Entry Grid.Column="1" Text="{Binding Name}" 
                                           Placeholder="Фамилия И.О." Margin="5,0"/>
                                    
                                    <!-- Капитан -->
                                    <Button Grid.Column="2" 
                                        Text="Cap" 
                                        FontAttributes="Bold"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnCaptainClicked"
                                        BackgroundColor="DarkGrey" 
                                        TextColor="Black"
                                        WidthRequest="40" HeightRequest="40"
                                        CornerRadius="10"
                                        Padding="0"                                            
                                        VerticalOptions="Center" HorizontalOptions="Center">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <!-- Нормальное состояние -->
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="DarkGray"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <!-- Наведение мыши (работает на Desktop) -->
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#007ACC"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>

                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsCaptain}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#007ACC"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <!-- Либеро -->
                                    <Button Grid.Column="3" 
                                        Text="Lib" 
                                        FontAttributes="Bold"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnLiberoClicked"
                                        BackgroundColor="DarkGrey" 
                                        TextColor="Black"
                                        WidthRequest="40" HeightRequest="40"
                                        CornerRadius="10"
                                        Padding="0"
                                        Margin="10,0,0,0"
                                        VerticalOptions="Center" HorizontalOptions="Center">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <!-- Нормальное состояние -->
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="DarkGray"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <!-- Наведение мыши (работает на Desktop) -->
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="LightGreen"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>

                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsLibero}" Value="True">
                                                <Setter Property="BackgroundColor" Value="LightGreen"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    
                                    <!-- Удалить -->
                                    <Label Grid.Column="4" Text="Del" FontSize="22" 
                                        TextColor="Red"
                                        VerticalOptions="Center" HorizontalOptions="End">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <!-- Нормальное состояние -->
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="TextColor" Value="Red"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <!-- Наведение мыши (работает на Desktop) -->
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="TextColor" Value="DarkRed"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>

                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="DeletePlayerClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="+ Добавить игрока (Хозяева)" 
                            Clicked="OnAddPlayerHomeClicked"
                            BackgroundColor="#E0E0E0" TextColor="Black">

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <!-- Нормальное состояние -->
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#E0E0E0"/>
                                        </VisualState.Setters>
                                    </VisualState>

                                    <!-- Наведение мыши (работает на Desktop) -->
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="Gray"/>
                                        </VisualState.Setters>
                                    </VisualState>

                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Button>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#007ACC" CornerRadius="10" Padding="10">
                <VerticalStackLayout>
                    <Label Text="Команда Гости" FontSize="18" FontAttributes="Bold" 
               TextColor="#007ACC"/>

                    <!-- Список игроков -->
                    <CollectionView x:Name="TeamGuestList" HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="40,*,Auto,Auto,40" Padding="5">

                                    <!-- Номер -->
                                    <Entry Grid.Column="0" Text="{Binding Number}" 
                               Keyboard="Numeric" Placeholder="№"
                               HorizontalTextAlignment="Center"/>

                                    <!-- ФИО -->
                                    <Entry Grid.Column="1" Text="{Binding Name}" 
                               Placeholder="Фамилия И.О." Margin="5,0"/>

                                    <!-- Капитан -->
                                    <Button Grid.Column="2" 
                                        Text="Cap" 
                                        FontAttributes="Bold"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnCaptainClicked"
                                        BackgroundColor="DarkGrey" 
                                        TextColor="Black"
                                        WidthRequest="40" HeightRequest="40"
                                        CornerRadius="10"
                                        Padding="0"                                            
                                        VerticalOptions="Center" HorizontalOptions="Center">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <!-- Нормальное состояние -->
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="DarkGrey"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <!-- Наведение мыши (работает на Desktop) -->
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#007ACC"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>

                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsCaptain}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#007ACC"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <!-- Либеро -->
                                    <Button Grid.Column="3" 
                                        Text="Lib" 
                                        FontAttributes="Bold"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnLiberoClicked"
                                        BackgroundColor="DarkGrey" 
                                        TextColor="Black"
                                        WidthRequest="40" HeightRequest="40"
                                        CornerRadius="10"
                                        Padding="0"
                                        Margin="10,0,0,0"
                                        VerticalOptions="Center" HorizontalOptions="Center">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <!-- Нормальное состояние -->
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="DarkGrey"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <!-- Наведение мыши (работает на Desktop) -->
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="LightGreen"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>

                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsLibero}" Value="True">
                                                <Setter Property="BackgroundColor" Value="LightGreen"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <!-- Удалить -->
                                    <Label Grid.Column="4" Text="Del" FontSize="22" 
                                        TextColor="Red"
                                        VerticalOptions="Center" HorizontalOptions="End">
                                        
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <!-- Нормальное состояние -->
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="TextColor" Value="Red"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <!-- Наведение мыши (работает на Desktop) -->
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="TextColor" Value="DarkRed"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>

                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="DeletePlayerClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>

                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="+ Добавить игрока (Гости)" 
                            Clicked="OnAddPlayerGuestClicked"
                            BackgroundColor="#E0E0E0" TextColor="Black">

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <!-- Нормальное состояние -->
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#E0E0E0"/>
                                        </VisualState.Setters>
                                    </VisualState>

                                    <!-- Наведение мыши (работает на Desktop) -->
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="Gray"/>
                                        </VisualState.Setters>
                                    </VisualState>

                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Button>
                </VerticalStackLayout>
            </Frame>

            <Label Text="⚠️ Проверяйте заполненные данные!&#10;Они отразятся в итоговом протоколе." 
               TextColor="DarkOrange" 
               FontAttributes="Italic"
               FontSize="14"
               HorizontalOptions="Center" 
               Margin="0,20,0,10"
               LineBreakMode="WordWrap"/>

            <!-- Кнопка начала матча -->
            <Button Text="🏐 Начать матч"
                FontSize="18"
                FontAttributes="Bold"
                BackgroundColor="#007ACC"
                TextColor="White"
                HeightRequest="50"
                CornerRadius="10"
                HorizontalOptions="Fill"
                VerticalOptions="End"
                Margin="0,0,0,20"
                Clicked="NextPageClick">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <!-- Нормальное состояние -->
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#007ACC"/>
                                </VisualState.Setters>
                            </VisualState>

                            <!-- Наведение мыши (работает на Desktop) -->
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Blue"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>