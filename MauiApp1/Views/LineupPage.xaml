<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.LineupPage"
             Title="Начальная расстановка"
             BackgroundColor="#FAFAFA">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#333333"
                Text="Хозяева">
            </Label>

            <Grid ColumnDefinitions="*,*,*" 
                        RowDefinitions="*,*"
                        ColumnSpacing="30" 
                        RowSpacing="15">

                <Grid Grid.Row="0" Grid.Column="0">

                    <Label x:Name="homePosLabel4"
                                Text="Зона 4"
                                TextColor="White"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                FontSize="14">
                    </Label>
                    
                    <Picker x:Name="homePosPicker4"
                                Title="Выберите игрока"
                                Opacity="0"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                SelectedIndexChanged="OnPlayerSelectedHome">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="0" Grid.Column="1">
                    
                    <Label x:Name="homePosLabel3"
                                Text="Зона 3"
                                TextColor="White"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                FontSize="14">
                    </Label>

                    <Picker x:Name="homePosPicker3"
                                Title="Выберите игрока"
                                Opacity="0"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                SelectedIndexChanged="OnPlayerSelectedHome">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="0" Grid.Column="2">

                    <Label x:Name="homePosLabel2"
                                Text="Зона 2"
                                TextColor="White"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                FontSize="14">
                    </Label>

                    <Picker x:Name="homePosPicker2"
                                Title="Выберите игрока"
                                Opacity="0"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                SelectedIndexChanged="OnPlayerSelectedHome">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="1" Grid.Column="0" >

                    <Label x:Name="homePosLabel5"
                            Text="Зона 5"
                            TextColor="White"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            FontSize="14">
                    </Label>

                    <Picker x:Name="homePosPicker5"
                            Title="Выберите игрока"
                            Opacity="0"
                            BackgroundColor="Transparent"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            SelectedIndexChanged="OnPlayerSelectedHome">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">

                    <Label x:Name="homePosLabel6"
                                Text="Зона 6"
                                TextColor="White"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                FontSize="14">
                    </Label>

                    <Picker x:Name="homePosPicker6"
                                Title="Выберите игрока"
                                Opacity="0"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                SelectedIndexChanged="OnPlayerSelectedHome">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="1" Grid.Column="2" >

                    <Label x:Name="homePosLabel1"
                                Text="Зона 1"
                                TextColor="White"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                FontSize="14">
                    </Label>

                    <Picker x:Name="homePosPicker1"
                                Title="Выберите игрока"
                                Opacity="0"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                SelectedIndexChanged="OnPlayerSelectedHome">
                    </Picker>
                    
                </Grid>

            </Grid>


            <Label
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#333333"
                Text="Гости">
            </Label>

            <Grid ColumnDefinitions="*,*,*" 
                    RowDefinitions="*,*,*"
                    ColumnSpacing="30" 
                    RowSpacing="15">

                <Grid  Grid.Row="1" Grid.Column="0">

                    <Label x:Name="guestPosLabel4"
                        Text="Зона 4"
                        TextColor="White"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        FontSize="14">
                    </Label>

                    <Picker x:Name="guestPosPicker4"
                        Title="Выберите игрока"
                        Opacity="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedIndexChanged="OnPlayerSelectedGuest">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">

                    <Label x:Name="guestPosLabel3"
                        Text="Зона 3"
                        TextColor="White"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        FontSize="14">
                    </Label>

                    <Picker x:Name="guestPosPicker3"
                        Title="Выберите игрока"
                        Opacity="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedIndexChanged="OnPlayerSelectedGuest">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="1" Grid.Column="2">

                    <Label x:Name="guestPosLabel2"
                        Text="Зона 2"
                        TextColor="White"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        FontSize="14">
                    </Label>

                    <Picker x:Name="guestPosPicker2"
                        Title="Выберите игрока"
                        Opacity="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedIndexChanged="OnPlayerSelectedGuest">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0">

                    <Label x:Name="guestPosLabel5"
                        Text="Зона 5"
                        TextColor="White"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        FontSize="14">
                    </Label>

                    <Picker x:Name="guestPosPicker5"
                        Title="Выберите игрока"
                        Opacity="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedIndexChanged="OnPlayerSelectedGuest">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="2" Grid.Column="1">

                    <Label x:Name="guestPosLabel6"
                        Text="Зона 6"
                        TextColor="White"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        FontSize="14">
                    </Label>

                    <Picker x:Name="guestPosPicker6"
                        Title="Выберите игрока"
                        Opacity="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedIndexChanged="OnPlayerSelectedGuest">
                    </Picker>
                    
                </Grid>

                <Grid Grid.Row="2" Grid.Column="2">

                    <Label x:Name="guestPosLabel1"
                        Text="Зона 1"
                        TextColor="White"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        FontSize="14">
                    </Label>

                    <Picker x:Name="guestPosPicker1"
                        Title="Выберите игрока"
                        Opacity="0"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        SelectedIndexChanged="OnPlayerSelectedGuest">
                    </Picker>
                    
                </Grid>

            </Grid>


            <Button Text="Начать партию"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#28A745"
                TextColor="White"
                HeightRequest="56"
                CornerRadius="12"
                HorizontalOptions="Fill"
                Clicked="OnStartMatchClicked">
            </Button>
            
        </VerticalStackLayout>

    </ScrollView>


</ContentPage>